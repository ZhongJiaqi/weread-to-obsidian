def parse_vault_frontmatter(path):
    """读单个 .md 文件，提取 frontmatter 关键字段，返回 dict 或 None。

    返回字段：{bookId, title, type, highlights, thoughts}

    返回 None 的情况：
    - 文件无 YAML frontmatter（开头不是 ---）
    - frontmatter 中缺 bookId（无法用作唯一标识）

    用正则手动解析，不引入 PyYAML，与项目 stdlib only 约束一致。
    只解析单行 key: value 形式，不处理嵌套/多行（这里只取 5 个字段都是单行）。
    """
    try:
        with open(path, encoding="utf-8") as f:
            txt = f.read()
    except (OSError, UnicodeDecodeError):
        return None

    m = re.match(r"^---\n(.*?)\n---\n", txt, re.S)
    if not m:
        return None

    fm = {}
    for line in m.group(1).splitlines():
        mm = re.match(r"^(\w+):\s*(.*)$", line)
        if mm:
            fm[mm.group(1)] = mm.group(2).strip().strip('"').strip("'")

    if "bookId" not in fm:
        return None

    return {
        "bookId": fm.get("bookId", ""),
        "title": fm.get("title", ""),
        "type": fm.get("type", ""),
        "highlights": int(fm.get("highlights", "0") or "0"),
        "thoughts": int(fm.get("thoughts", "0") or "0"),
    }


def scan_vault(out_dir):
    """遍历 out_dir 下所有 .md 文件，解析 frontmatter，
    返回 {bookId: {path, title, highlights, thoughts}}。

    跳过条件：
    - 文件名以 _ 开头（_读书档案.md 等索引）
    - frontmatter 解析返回 None（无 frontmatter 或缺 bookId）
    - type != "读书笔记"（资料/索引等非笔记文件）

    目录不存在返回 {}。
    """
    if not os.path.isdir(out_dir):
        return {}

    books = {}
    for fn in os.listdir(out_dir):
        if not fn.endswith(".md") or fn.startswith("_"):
            continue
        path = os.path.join(out_dir, fn)
        rec = parse_vault_frontmatter(path)
        if rec is None:
            continue
        if rec.get("type") != "读书笔记":
            continue
        books[rec["bookId"]] = {
            "path": path,
            "title": rec["title"],
            "highlights": rec["highlights"],
            "thoughts": rec["thoughts"],
        }
    return books


def diff_vault_vs_api(vault, api_books, include_reading=False):
    """对比 vault 与 API list，返回三类 drift 计划。

    Args:
        vault: scan_vault 返回值 {bookId: {path, title, highlights, thoughts}}
        api_books: list_notebooks 返回值，每条含
            {bookId, book: {title, author}, readingProgress, noteCount, reviewCount}
        include_reading: True 时 missing 类不要求 progress >= 90

    Returns:
        {
            "missing": [{bookId, title, author, noteCount, reviewCount}, ...],
            "stale":   [{bookId, title, author, path, vault_highlights, vault_thoughts,
                         api_noteCount, api_reviewCount}, ...],
            "orphan":  [{bookId, title, path, highlights, thoughts}, ...],
        }

    字段映射约束（已实测对齐）：
        API noteCount   ↔ vault highlights
        API reviewCount ↔ vault thoughts
    """
    api_by_id = {nb.get("bookId"): nb for nb in api_books if nb.get("bookId")}

    missing = []
    stale = []
    for bid, nb in api_by_id.items():
        bk = nb.get("book") or {}
        note_count = nb.get("noteCount", 0)
        review_count = nb.get("reviewCount", 0)

        if bid not in vault:
            if include_reading or is_finished(nb):
                missing.append({
                    "bookId": bid,
                    "title": bk.get("title", ""),
                    "author": bk.get("author", ""),
                    "noteCount": note_count,
                    "reviewCount": review_count,
                })
            continue

        v = vault[bid]
        if (v["highlights"] != note_count
                or v["thoughts"] != review_count):
            stale.append({
                "bookId": bid,
                "title": bk.get("title", "") or v["title"],
                "author": bk.get("author", ""),
                "path": v["path"],
                "vault_highlights": v["highlights"],
                "vault_thoughts": v["thoughts"],
                "api_noteCount": note_count,
                "api_reviewCount": review_count,
            })

    orphan = []
    for bid, v in vault.items():
        if bid not in api_by_id:
            orphan.append({
                "bookId": bid,
                "title": v["title"],
                "path": v["path"],
                "highlights": v["highlights"],
                "thoughts": v["thoughts"],
            })

    return {"missing": missing, "stale": stale, "orphan": orphan}


def print_sync_report(plan, applied, vault_count):
    """渲染 drift 报告到 stdout。

    Args:
        plan: diff_vault_vs_api 返回值
        applied: True 表示 --apply 模式（不打印 "加 --apply 真正执行" 提示）
        vault_count: vault 已扫描到的书本数（用于无 drift 时的"7 本"提示）
    """
    m, s, o = plan["missing"], plan["stale"], plan["orphan"]

    if not (m or s or o):
        print(f"✅ vault 与微信读书已同步（{vault_count} 本）")
        return

    if m:
        print(f"\n📥 缺失（{len(m)} 本）：")
        for it in m:
            print(f"  · {it['title']} — {it['author']}"
                  f"（{it['noteCount']} 划 / {it['reviewCount']} 想）")

    if s:
        print(f"\n🔄 过期（{len(s)} 本）：")
        for it in s:
            print(f"  · {it['title']} — 本地 "
                  f"{it['vault_highlights']}/{it['vault_thoughts']} → "
                  f"微信读书 {it['api_noteCount']}/{it['api_reviewCount']}")

    if o:
        print(f"\n👻 孤儿（vault 在但微信读书 list 没有，{len(o)} 本）：")
        for it in o:
            print(f"  · {it['title']}（{it['highlights']} 划 / "
                  f"{it['thoughts']} 想；{it['path']}）")
        print("  → 不动 vault。可能是 API key 切换 / 微信读书删书，需人工处理。")

    if not applied:
        n_pull = len(m)
        n_refresh = len(s)
        est_sec = (n_pull + n_refresh) * 10
        print(f"\n→ 计划：拉 {n_pull} 本 + 重拉 {n_refresh} 本（约 {est_sec} 秒）")
        print("→ dry-run。加 --apply 真正执行。")


def apply_sync_plan(plan, out_dir):
    """执行同步计划：拉缺失 + 刷过期。孤儿不动。

    Args:
        plan: diff_vault_vs_api 返回值
        out_dir: vault 子目录绝对路径

    Returns:
        {"synced": N, "failed": [{"bookId", "title", "reason"}, ...]}

    单本 fetch 失败（SystemExit）会被 catch，记录到 failed 后继续其他书。
    """
    synced = 0
    failed = []

    def _write_book(bid, title, author, target_path):
        try:
            bm, rv = fetch_book_notes(bid)
            best = fetch_best_bookmarks(bid)
            best_thoughts = fetch_thoughts_for_bookmarks(bid, best)
            md = build_markdown(bid, title, author or "", bm, rv,
                                best, best_thoughts)
            with open(target_path, "w", encoding="utf-8") as f:
                f.write(md)
            return True, None
        except SystemExit as e:
            return False, str(e)

    for item in plan["missing"]:
        bid = item["bookId"]
        title = item["title"]
        path = os.path.join(out_dir, safe_filename(title) + ".md")
        ok, reason = _write_book(bid, title, item["author"], path)
        if ok:
            print(f"✓ 拉取: {title}")
            synced += 1
        else:
            print(f"✗ 拉取失败: {title} — {reason}")
            failed.append({"bookId": bid, "title": title, "reason": reason})

    for item in plan["stale"]:
        bid = item["bookId"]
        title = item["title"]
        # stale 时用 vault 现有路径覆写，保护用户重命名/移动
        path = item["path"]
        ok, reason = _write_book(bid, title, item.get("author", ""), path)
        if ok:
            print(f"✓ 重拉: {title}")
            synced += 1
        else:
            print(f"✗ 重拉失败: {title} — {reason}")
            failed.append({"bookId": bid, "title": title, "reason": reason})

    return {"synced": synced, "failed": failed}


def update_protected_section(path, content, dry_run=False):
    """在文件里替换保护区内容（START/END 标记之间）。

    场景：
    1. 文件不存在 → 用 _TEMPLATE 新建
    2. 文件存在但没标记 → 在 H1（第一行 # 开头）之后插入保护区
    3. 文件存在且标记完整 → 替换标记之间的内容
    4. 只有 START 没有 END → 抛 SystemExit 警告，不修改

    dry_run=True 时返回最终字符串但不写文件。
    """
    block = f"{PROFILE_START}\n{content}\n{PROFILE_END}"

    if not os.path.exists(path):
        new_text = _TEMPLATE.format(start=PROFILE_START, content=content, end=PROFILE_END)
        if not dry_run:
            parent = os.path.dirname(path)
            if parent:
                os.makedirs(parent, exist_ok=True)
            with open(path, "w", encoding="utf-8") as f:
                f.write(new_text)
        return new_text

    with open(path, encoding="utf-8") as f:
        text = f.read()
    has_start = "<!-- WEREAD-PROFILE-START" in text
    has_end = PROFILE_END in text

    if (has_start and not has_end) or (has_end and not has_start):
        sys.exit(
            f"ERROR: {path} 含不完整的保护区标记（START/END 必须成对出现）。"
            f"请先修复后再跑 --profile。"
        )

    if has_start and has_end:
        # 替换标记之间内容（兼容旧版无 suffix 的 START 标记）
        start_idx = text.find("<!-- WEREAD-PROFILE-START")
        end_idx = text.find(PROFILE_END) + len(PROFILE_END)
        new_text = text[:start_idx] + block + text[end_idx:]
    else:
        # 没标记 → 在 H1 之后插入
        lines = text.split("\n")
        h1_idx = next((i for i, ln in enumerate(lines) if ln.startswith("# ")), -1)
        if h1_idx < 0:
            # 没 H1 也没标记 → 顶部插入
            new_text = block + "\n\n" + text
        else:
            insert_at = h1_idx + 1
            new_lines = lines[:insert_at] + ["", block, ""] + lines[insert_at:]
            new_text = "\n".join(new_lines)

    if not dry_run:
        with open(path, "w", encoding="utf-8") as f:
            f.write(new_text)
    return new_text


def fetch_readdata_overall():
    """调 /readdata/detail mode=overall。返回 dict。"""
    return api("/readdata/detail", mode="overall")


def main_sync(args, out_dir):
    """--sync 子命令入口：诊断 vault 与微信读书的 drift。

    默认 dry-run（仅打印计划）。加 --apply 才真正执行 missing + stale 同步。
    孤儿（vault 有但 API list 无）永远只警告，不动 vault。
    """
    vault = scan_vault(out_dir)
    print(f"扫描 vault... {len(vault)} 本")

    api_books = list_notebooks()
    print(f"拉取微信读书 list... {len(api_books)} 本有笔记")

    plan = diff_vault_vs_api(vault, api_books,
                              include_reading=args.include_reading)

    if args.apply:
        print_sync_report(plan, applied=True, vault_count=len(vault))
        if not (plan["missing"] or plan["stale"]):
            return
        os.makedirs(out_dir, exist_ok=True)
        result = apply_sync_plan(plan, out_dir)
        n_fail = len(result["failed"])
        print(f"\n完成: {result['synced']} 本同步 / {n_fail} 失败")
    else:
        print_sync_report(plan, applied=False, vault_count=len(vault))


def main_profile(args, out_dir):
    """--profile 子命令入口。out_dir 是 vault 内子目录路径。"""
    profile_path = os.path.join(out_dir, "_读书档案.md")
    data = fetch_readdata_overall()
    profile_md = build_profile_markdown(data)

    if args.dry_run:
        final = update_protected_section(profile_path, profile_md, dry_run=True)
        print(final)
        return

    update_protected_section(profile_path, profile_md)
    print(f"✅ 画像已更新：{profile_path}")


def build_markdown(book_id, title, author, bm_data, rv_data, best_data=None,
                   best_thoughts=None):
    bookmarks = bm_data.get("updated") or []
    reviews = [r["review"] for r in (rv_data.get("reviews") or [])]
    chapters = bm_data.get("chapters") or []
    chap_title = {c["chapterIdx"]: c["title"] for c in chapters}

    bm_by_chap = defaultdict(list)
    for b in bookmarks:
        bm_by_chap[b.get("chapterIdx", 0)].append(b)
    rv_by_chap = defaultdict(list)
    for r in reviews:
        rv_by_chap[r.get("chapterIdx", 0)].append(r)
    rv_ranges = defaultdict(set)
    for r in reviews:
        rv_ranges[r.get("chapterIdx", 0)].add(r.get("range"))

    times = [b["createTime"] for b in bookmarks if b.get("createTime")]
    start = datetime.fromtimestamp(min(times)).strftime("%Y-%m-%d") if times else ""
    end = datetime.fromtimestamp(max(times)).strftime("%Y-%m-%d") if times else ""

    lines = []
    lines += [
        "---",
        f'title: "{title}"',
        f'author: "[[{author}]]"',
        f"bookId: {book_id}",
        "source: 微信读书",
        "type: 读书笔记",
        f"started: {start}",
        f"finished: {end}",
        f"highlights: {len(bookmarks)}",
        f"thoughts: {len(reviews)}",
        "tags:",
        "  - 读书笔记",
        f"weread: weread://reading?bId={book_id}",
        f"exported: {datetime.now().strftime('%Y-%m-%d %H:%M')}",
        "---",
        "",
        f"# 《{title}》",
        "",
        f"**作者**：[[{author}]]" if author else "",
        f"**阅读跨度**：{start} → {end}" if start else "",
        f"**笔记规模**：{len(bookmarks)} 条划线・{len(reviews)} 条想法",
        f"**App 跳转**：[在微信读书中打开](weread://reading?bId={book_id})",
        "",
    ]

    # 末尾"💡 热门划线"段的统计提前算，用于目录段
    best_items = (best_data or {}).get("items") or []
    best_thoughts_map = best_thoughts or {}
    best_section_title = "💡 热门划线 · 别人的想法"

    all_idx = sorted(set(list(bm_by_chap.keys()) + list(rv_by_chap.keys())))
    if all_idx:
        lines.append("> [!summary] 📑 全文导航")
        lines.append("> ")
        for idx in all_idx:
            t = chap_title.get(idx, f"章节 {idx}")
            lines.append(
                f"> - [[#{t}|{t}]] — {len(bm_by_chap[idx])} 划线，"
                f"**{len(rv_by_chap[idx])} 想法**"
            )
        if best_items:
            n_th = sum(len(v) for v in best_thoughts_map.values())
            lines.append(
                f"> - [[#{best_section_title}|{best_section_title}]] — "
                f"Top {len(best_items)} 划线 + {n_th} 高赞想法"
            )
        lines.append("")
        lines.append("---")
        lines.append("")

    for idx in all_idx:
        t = chap_title.get(idx, f"章节 {idx}")
        n_bm, n_rv = len(bm_by_chap[idx]), len(rv_by_chap[idx])
        lines += [f"## {t}", f"_{n_bm} 划线 ・ {n_rv} 想法_", ""]

        chap_reviews = sorted(rv_by_chap[idx], key=lambda r: range_start(r.get("range")))
        if chap_reviews:
            lines += ["### 💭 我的想法", ""]
            for r in chap_reviews:
                abstract = (r.get("abstract") or "").strip()
                content = (r.get("content") or "").strip()
                ts = r.get("createTime")
                ts_str = datetime.fromtimestamp(ts).strftime("%Y-%m-%d") if ts else ""
                chap_uid = r.get("chapterUid")
                rng = r.get("range") or ""
                jump = ""
                if chap_uid and "-" in rng:
                    rs, re_ = rng.split("-", 1)
                    jump = (
                        f"weread://bestbookmark?bookId={book_id}"
                        f"&chapterUid={chap_uid}&rangeStart={rs}&rangeEnd={re_}"
                    )
                lines.append("> [!quote]")
                for ln in abstract.split("\n"):
                    lines.append(f"> {ln}")
                lines.append("")
                lines.append(f"**▸** {content}")
                lines.append(
                    f"<sub>{ts_str} · [跳转]({jump})</sub>" if jump else f"<sub>{ts_str}</sub>"
                )
                lines.append("")

        pure = [b for b in bm_by_chap[idx] if b.get("range") not in rv_ranges[idx]]
        pure.sort(key=lambda b: range_start(b.get("range")))
        if pure:
            lines += ["### ✍️ 划线", ""]
            for b in pure:
                text = (b.get("markText") or "").strip()
                for ln in text.split("\n"):
                    lines.append(f"> {ln}")
                lines.append("")
        lines += ["---", ""]

    # 全书热门划线 + 划线下的高赞想法
    # 来自 /book/bestbookmarks（Top 20 热门划线）+ /book/readreviews（每条划线下的 Top 3 高赞想法）
    items = best_items
    if items:
        best_chap_title = {
            c["chapterUid"]: c["title"]
            for c in ((best_data or {}).get("chapters") or [])
            if "chapterUid" in c and "title" in c
        }
        # 我的划线集合，用于标注"⭐ 我也划了"
        my_marks = {
            (b.get("chapterUid"), b.get("range"))
            for b in bookmarks
            if b.get("chapterUid") and b.get("range")
        }
        thoughts_map = best_thoughts_map

        lines += [
            f"## {best_section_title}",
            "",
            f"<sub>来自微信读书全平台 · Top {len(items)} 划线 · "
            "每条精选 Top 3 高赞想法（按点赞数排序）</sub>",
            "",
        ]
        for item in items:
            text = (item.get("markText") or "").strip()
            count = item.get("totalCount", 0)
            chap_uid = item.get("chapterUid")
            rng = item.get("range") or ""
            chap_t = best_chap_title.get(chap_uid, "")
            also_mine = (chap_uid, rng) in my_marks

            for ln in text.split("\n"):
                lines.append(f"> {ln}")

            meta = [f"🔥 **{count:,}** 人划线"]
            if chap_t:
                meta.append(f"📖 {chap_t}")
            if also_mine:
                meta.append("⭐ 我也划了")
            if chap_uid and "-" in rng:
                rs, re_ = rng.split("-", 1)
                jump = (
                    f"weread://bestbookmark?bookId={book_id}"
                    f"&chapterUid={chap_uid}&rangeStart={rs}&rangeEnd={re_}"
                )
                meta.append(f"[跳转]({jump})")
            lines.append(f"<sub>{' · '.join(meta)}</sub>")
            lines.append("")

            # 这条划线下别人写的高赞想法
            for pr in thoughts_map.get((chap_uid, rng), []):
                rv = pr.get("review") or {}
                name = (rv.get("author") or {}).get("name") or "匿名读者"
                likes = pr.get("likesCount") or 0
                content = _trim_thought(rv.get("content"))
                lines.append(f"> > **▸ {name}** <sub>👍 {likes:,}</sub>")
                for ln in content.split("\n"):
                    lines.append(f"> > {ln}")
                lines.append("")

    return "\n".join(lines)


def main():
    p = argparse.ArgumentParser(
        description="WeRead → Obsidian 笔记导入工具",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__,
    )
    p.add_argument("query", nargs="?", help="书名（部分匹配）或 bookId")
    p.add_argument("--list", action="store_true", help="列出所有有笔记的书")
    p.add_argument("--all", action="store_true",
                   help="批量导入已读完的书（进度 >= 90%%）")
    p.add_argument(
        "--profile",
        action="store_true",
        help="更新 _读书档案.md 顶部的读者画像（数量 + 品味）",
    )
    p.add_argument("--include-reading", action="store_true",
                   help="配合 --all 时，也导入在读的书")
    p.add_argument("--force", action="store_true", help="文件已存在时覆盖")
    p.add_argument("--dry-run", action="store_true", help="只显示会写哪些文件")
    p.add_argument(
        "--sync",
        action="store_true",
        help="对比 vault 与微信读书，输出 drift 报告（默认 dry-run，加 --apply 真正执行）",
    )
    p.add_argument(
        "--apply",
        action="store_true",
        help="配合 --sync 时真正执行同步操作",
    )
    p.add_argument(
        "--vault",
        default=os.environ.get("WEREAD_VAULT", DEFAULT_VAULT),
        help="Obsidian vault 路径",
    )
    p.add_argument(
        "--subdir",
        default=os.environ.get("WEREAD_SUBDIR", DEFAULT_SUBDIR),
        help="vault 内子目录",
    )
    args = p.parse_args()

    out_dir = os.path.join(args.vault, args.subdir)
    if not args.dry_run:
        os.makedirs(out_dir, exist_ok=True)

    if args.profile:
        main_profile(args, out_dir)
        return

    if args.apply and not args.sync:
        sys.exit("--apply 必须配合 --sync 使用")

    if args.sync:
        main_sync(args, out_dir)
        return

    nbs = list_notebooks()

    if args.list:
        def total(b):
            return b.get("reviewCount", 0) + b.get("noteCount", 0) + b.get("bookmarkCount", 0)
        ordered = sorted(nbs, key=total, reverse=True)
        print(f"共 {len(nbs)} 本有笔记（总 {sum(total(b) for b in nbs)} 条）：\n")
        for i, b in enumerate(ordered, 1):
            bk = b.get("book") or {}
            print(f"  {i:>2}. {bk.get('title')} — {bk.get('author')}  "
                  f"({total(b)} 条；bookId={b.get('bookId')})")
        return

    targets = []  # (bookId, title, author)
    skipped_reading = []
    if args.all:
        for nb in nbs:
            bk = nb.get("book") or {}
            if not is_finished(nb) and not args.include_reading:
                skipped_reading.append(bk.get("title"))
                continue
            targets.append((nb.get("bookId"), bk.get("title"), bk.get("author")))
    elif args.query:
        # 单本指名时总是导入，不管读没读完 —— 用户主动要看
        bid, title, author = find_book(args.query, nbs)
        if not bid:
            sys.exit(f"未找到匹配 '{args.query}' 的书（请用 --list 查看清单）")
        targets.append((bid, title, author))
    else:
        p.print_help()
        sys.exit(1)

    for bid, title, author in targets:
        filename = safe_filename(title) + ".md"
        path = os.path.join(out_dir, filename)
        existing = os.path.exists(path)

        if existing and not args.force:
            print(f"⏭  跳过（已存在）: {filename} — 用 --force 覆盖")
            continue
        if args.dry_run:
            tag = "覆盖" if existing else "新增"
            print(f"[dry-run] {filename}  ({tag})")
            continue

        bm, rv = fetch_book_notes(bid)
        best = fetch_best_bookmarks(bid)
        best_thoughts = fetch_thoughts_for_bookmarks(bid, best)
        md = build_markdown(bid, title, author or "", bm, rv, best, best_thoughts)
        with open(path, "w", encoding="utf-8") as f:
            f.write(md)

        n_bm = len(bm.get("updated") or [])
        n_rv = len(rv.get("reviews") or [])
        n_best = len((best or {}).get("items") or [])
        n_thoughts = sum(len(v) for v in (best_thoughts or {}).values())
        extra = f" + {n_best} 热门划线 + {n_thoughts} 高赞想法" if n_best else ""
        print(f"✅ {filename}  ({n_bm} 划线 + {n_rv} 想法{extra})")

    if skipped_reading:
        print(f"\n📕 跳过 {len(skipped_reading)} 本在读的书（用 --include-reading 包含）")
        for t in skipped_reading[:5]:
            print(f"    · {t}")
        if len(skipped_reading) > 5:
            print(f"    ... 共 {len(skipped_reading)} 本")


if __name__ == "__main__":
    main()
