#!/usr/bin/env python3
"""
weread-to-obsidian — 把微信读书一本书的划线+想法整理成 Obsidian 笔记

用法:
  weread-to-obsidian <书名或bookId>        # 整理单本
  weread-to-obsidian --list                # 列出所有有笔记的书
  weread-to-obsidian --all                 # 批量导入所有有笔记的书
  weread-to-obsidian <书名> --force        # 已存在时覆盖
  weread-to-obsidian <书名> --dry-run      # 只显示会发生什么，不写文件

环境变量:
  WEREAD_API_KEY    必填，wrk-xxxxx 格式
  WEREAD_VAULT      可选，Obsidian vault 路径
                    (默认: ~/Library/Mobile Documents/iCloud~md~obsidian/Documents)
  WEREAD_SUBDIR     可选，vault 下的子目录 (默认: 读书笔记)
"""
import argparse
import json
import os
import re
import sys
import urllib.request
import urllib.error
from collections import defaultdict
from datetime import datetime

API = "https://i.weread.qq.com/api/agent/gateway"
SKILL_VERSION = "1.0.3"

DEFAULT_VAULT = os.path.expanduser(
    "~/Library/Mobile Documents/iCloud~md~obsidian/Documents"
)
DEFAULT_SUBDIR = "读书笔记"


def api(api_name, **params):
    """Call the WeRead agent gateway. Returns parsed JSON."""
    key = os.environ.get("WEREAD_API_KEY")
    if not key:
        sys.exit("ERROR: WEREAD_API_KEY 未设置 (export WEREAD_API_KEY=wrk-xxx)")
    body = {"api_name": api_name, "skill_version": SKILL_VERSION, **params}
    req = urllib.request.Request(
        API,
        data=json.dumps(body).encode("utf-8"),
        headers={
            "Authorization": f"Bearer {key}",
            "Content-Type": "application/json",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=30) as resp:
            data = json.loads(resp.read().decode("utf-8"))
    except urllib.error.URLError as e:
        sys.exit(f"ERROR: 网络/接口失败: {e}")
    if isinstance(data, dict) and data.get("errcode"):
        sys.exit(f"ERROR: WeRead API {data.get('errcode')}: {data.get('errmsg')}")
    return data


def is_finished(nb):
    """判断一本书是否读完。只看 readingProgress >= 90，
    有意忽略 markedStatus —— 经验上 markedStatus 不准
    （用户经常误标或没改），progress >= 90 是更可信的'读完'信号。"""
    return nb.get("readingProgress", 0) >= 90


def list_notebooks():
    """Return all books that have notes, with full pagination."""
    out = []
    last_sort = None
    while True:
        params = {"count": 100}
        if last_sort is not None:
            params["lastSort"] = last_sort
        d = api("/user/notebooks", **params)
        batch = d.get("books") or []
        out.extend(batch)
        if d.get("hasMore") != 1 or not batch:
            break
        last_sort = batch[-1].get("sort")
        if last_sort is None:
            break
    return out


def find_book(query, notebooks):
    """Resolve query (bookId or partial title) to (bookId, title, author)."""
    # bookId 直接匹配
    for nb in notebooks:
        if nb.get("bookId") == query:
            b = nb.get("book") or {}
            return query, b.get("title", query), b.get("author", "")
    # 书名包含匹配
    candidates = [
        nb for nb in notebooks
        if query in ((nb.get("book") or {}).get("title") or "")
    ]
    if not candidates:
        return None, None, None
    if len(candidates) > 1:
        print(f"找到多本匹配 '{query}':")
        for i, nb in enumerate(candidates, 1):
            b = nb.get("book") or {}
            print(f"  {i}. {b.get('title')} — {b.get('author')} (bookId={nb.get('bookId')})")
        sys.exit("请用更精确的书名或 bookId 重试")
    nb = candidates[0]
    b = nb.get("book") or {}
    return nb.get("bookId"), b.get("title"), b.get("author")


def fetch_book_notes(book_id):
    """Fetch all bookmarks + reviews for a book. count=200 cap is enough."""
    bm = api("/book/bookmarklist", bookId=book_id)
    rv = api("/review/list/mine", bookid=book_id, count=200, synckey=0)
    return bm, rv


def fetch_best_bookmarks(book_id):
    """Fetch global popular highlights (Top 20). Returns None on failure
    so the main flow stays unaffected for cold books or transient errors."""
    try:
        return api("/book/bestbookmarks", bookId=book_id)
    except SystemExit:
        return None


def _is_quality_thought(pr):
    """过滤策略：
    - 至少 3 个赞（< 3 视为没被认同的个人感悟）
    - 长文（>500 字）必须高赞（>=500 赞），否则视为 AI 灌水
    """
    likes = pr.get("likesCount") or 0
    if likes < 3:
        return False
    content = ((pr.get("review") or {}).get("content") or "").strip()
    if len(content) > 500 and likes < 500:
        return False
    return True


def fetch_thoughts_for_bookmarks(book_id, best_data, per_range=3, fetch_count=20):
    """对热门划线的每条 range 拉别人写的想法，按 likesCount 降序取 Top N。

    返回 {(chapterUid, range): [pageReview, ...]}。失败时返回 {} 不阻塞主流程。

    /book/readreviews 一次请求要求同一个 chapterUid，所以按章节分组批量调用。
    pageReviews 默认不是按点赞数排序的，必须客户端重排。
    fetch_count=20 是接口上限，拉满让候选更全。
    """
    items = (best_data or {}).get("items") or []
    if not items:
        return {}

    by_chap = defaultdict(list)
    for item in items:
        chap_uid = item.get("chapterUid")
        rng = item.get("range")
        if chap_uid and rng:
            by_chap[chap_uid].append(rng)

    out = {}
    for chap_uid, ranges in by_chap.items():
        try:
            data = api(
                "/book/readreviews",
                bookId=book_id,
                chapterUid=chap_uid,
                reviews=[{"range": r, "count": fetch_count} for r in ranges],
            )
        except SystemExit:
            continue
        for rg in data.get("reviews") or []:
            page = rg.get("pageReviews") or []
            quality = [p for p in page if _is_quality_thought(p)]
            quality.sort(key=lambda p: p.get("likesCount", 0), reverse=True)
            top = quality[:per_range]
            if top:
                out[(chap_uid, rg.get("range"))] = top
    return out


def _trim_thought(content, limit=400):
    """清理 markdown 控制字符 + 截到 limit 字。

    保留正常分段内容（如"繁荣"那种 5000+ 赞的精华长想法），同时移除
    会破坏嵌套引用渲染的元素：
    - 独占一行的水平线 `---` → 删除（否则在 `> >` 嵌套引用里渲染成 hr）
    - 行首 `## 标题` → 转 `**粗体**`（保留强调，不破坏标题层级）
    - 三个以上连续空行 → 合并
    """
    raw = (content or "").strip()
    raw = re.sub(r"\n-{3,}(?=\n|$)", "", raw)
    raw = re.sub(r"(?m)^#{1,6}\s+(.+)$", r"**\1**", raw)
    raw = re.sub(r"\n{3,}", "\n\n", raw).strip()
    if len(raw) > limit:
        return raw[:limit].rstrip() + "…"
    return raw


def range_start(s):
    try:
        return int((s or "0").split("-", 1)[0])
    except Exception:
        return 0


def safe_filename(name):
    """Strip characters Obsidian/macOS dislike in filenames."""
    name = re.sub(r"[\\/:*?\"<>|\n\r\t]", " ", name)
    return name.strip()[:120]


def format_hours(seconds):
    """秒数 → 人类可读时长。
    < 1 小时 显示 N 分钟，否则显示 N.Nh（保留 1 位小数）。
    """
    if seconds <= 0:
        return "0h"
    if seconds < 3600:
        return f"{max(1, int(round(seconds / 60)))} 分钟"
    return f"{round(seconds / 3600, 1)}h"


def ascii_bar(value, max_value, width=20, char="▮"):
    """画一行等宽 ascii bar。value=0 或 max_value<=0 时至少 1 格，避免空字符串。"""
    if max_value <= 0 or value <= 0:
        return char
    n = min(width, max(1, int(round(value / max_value * width))))
    return char * n


# 实用书类别白名单（用于"实用书阅读者"洞察的分子计算）
PRACTICAL_CATEGORIES = {"心理", "个人成长", "经济理财", "管理"}


def derive_insights(data):
    """基于 readdata/detail 的字段推导出几条简单规则的洞察文案。

    返回字符串列表，调用方可自行选择渲染位置。规则：
    1. 读龄：注册到今年的差（年）
    2. 爆发之年：今年时长 / 去年时长 > 1.5 →"今年是你的爆发之年（N×）"
    3. 白天读书人：18-23 点时长 / 全天 < 10% → 文案
    4. 实用书阅读者：实用类时长 / 总时长 > 80% → "实用书 ≈ X%"
    """
    insights = []
    now = datetime.now()

    # 1. 读龄
    reg = data.get("registTime")
    if reg:
        reg_year = datetime.fromtimestamp(reg).year
        years = now.year - reg_year
        if years >= 1:
            insights.append(f"{years} 年读龄（自 {reg_year} 年起）")

    # 2. 爆发之年
    rt = data.get("readTimes") or {}
    if rt:
        by_year = defaultdict(int)
        for ts, secs in rt.items():
            if str(ts).isdigit():
                by_year[datetime.fromtimestamp(int(ts)).year] += secs
        this_y = by_year.get(now.year, 0)
        last_y = by_year.get(now.year - 1, 0)
        if last_y > 0 and this_y / last_y > 1.5:
            insights.append(
                f"今年是你的爆发之年（{this_y / last_y:.1f}× 去年）"
            )

    # 3. 白天读书人
    pt = data.get("preferTime") or []
    if len(pt) == 24:
        night = sum(pt[18:24])
        total = sum(pt)
        if total > 0 and night / total < 0.10:
            insights.append("白天读书人：18 点后几乎不读")

    # 4. 实用书占比
    cats = data.get("preferCategory") or []
    if cats:
        total_time = sum(c.get("readingTime", 0) for c in cats)
        practical_time = sum(
            c.get("readingTime", 0) for c in cats
            if c.get("categoryTitle") in PRACTICAL_CATEGORIES
        )
        if total_time > 0 and practical_time / total_time > 0.80:
            pct = round(practical_time / total_time * 100)
            insights.append(f"实用书阅读者 ≈ {pct}%")

    return insights


def build_quantity_callout(data):
    """构造 📊 数量画像 callout（Obsidian 兼容格式）。返回 markdown 多行字符串。"""
    lines = ["> [!example] 📊 数量画像"]

    # 阅读漏斗：从 readStat 取 读过/读完/阅读 三个
    stat_map = {s.get("stat"): s.get("counts", "") for s in data.get("readStat") or []}
    funnel_parts = []
    for key in ("读过", "读完", "阅读"):
        v = stat_map.get(key)
        if v:
            # "33本" → "33 本"；"251天" → "251 天"
            display = re.sub(r"\s*(本|天)\s*$", r" \1", v).strip()
            funnel_parts.append(f"{key} **{display}**")
    if funnel_parts:
        lines.append(f"> - **阅读漏斗**：{' · '.join(funnel_parts)}")

    # 累计投入：totalReadTime + 笔记数
    total_h = format_hours(data.get("totalReadTime", 0))
    notes_count = stat_map.get("笔记", "0条").replace("条", "").strip()
    try:
        notes_int = int(notes_count)
        notes_display = f"{notes_int:,}"
    except ValueError:
        notes_display = notes_count
    lines.append(f"> - **累计投入**：**{total_h}** · 笔记 **{notes_display} 条**")

    # 入坑时间 + 读龄
    reg = data.get("registTime")
    if reg:
        reg_date = datetime.fromtimestamp(reg).strftime("%Y-%m-%d")
        years = datetime.now().year - datetime.fromtimestamp(reg).year
        lines.append(f"> - **入坑时间**：{reg_date}（**{years} 年读龄**）")

    # 年度趋势
    rt = data.get("readTimes") or {}
    if rt:
        by_year_map = defaultdict(int)
        for ts, secs in rt.items():
            if str(ts).isdigit():
                by_year_map[datetime.fromtimestamp(int(ts)).year] += secs
        by_year = sorted(by_year_map.items())
        max_secs = max(secs for _, secs in by_year) if by_year else 1
        lines.append("> - **年度趋势**：")
        lines.append("> ```")
        cur_year = datetime.now().year
        for yr, secs in by_year:
            hrs = round(secs / 3600, 1)
            bar = ascii_bar(secs, max_secs, width=20)
            mark = " ← 进行中" if yr == cur_year else ""
            lines.append(f"> {yr}  {bar:20}  {hrs}h{mark}")
        lines.append("> ```")

    # 单本时长 Top 3
    longest = data.get("readLongest") or []
    if longest:
        parts = []
        for b in longest[:3]:
            title = (b.get("book") or {}).get("title") or ""
            hrs = round(b.get("readTime", 0) / 3600, 1)
            if title:
                parts.append(f"[[{title}]] {hrs}h")
        if parts:
            lines.append(f"> - **单本时长 Top 3**：{' · '.join(parts)}")

    # 勋章
    medals = data.get("medals") or []
    if medals:
        top_names = [m.get("displayText") or m.get("hint") or "" for m in medals[:5]]
        top_names = [n for n in top_names if n]
        suffix = " / ..." if len(medals) > 5 else ""
        if top_names:
            lines.append(f"> - **🏅 勋章**：{len(medals)} 枚（{' / '.join(top_names)}{suffix}）")
        else:
            lines.append(f"> - **🏅 勋章**：{len(medals)} 枚")

    return "\n".join(lines)


def _parse_chinese_duration(s):
    """将 '16小时44分钟' / '45小时18分钟' 解析为分钟数，用于排序。失败返回 0。"""
    if not isinstance(s, str):
        return 0
    h_match = re.search(r"(\d+)\s*小时", s)
    m_match = re.search(r"(\d+)\s*分钟", s)
    h = int(h_match.group(1)) if h_match else 0
    m = int(m_match.group(1)) if m_match else 0
    return h * 60 + m


def build_taste_callout(data):
    """构造 🎨 品味画像 callout。返回 markdown 多行字符串。"""
    lines = ["> [!quote] 🎨 品味画像"]

    # 类别偏好（按时长 Top 4）+ 实用书占比洞察
    cats = sorted(
        data.get("preferCategory") or [],
        key=lambda c: c.get("readingTime", 0),
        reverse=True,
    )[:4]
    if cats:
        parts = [
            f"{c.get('categoryTitle')} {round(c.get('readingTime', 0) / 3600, 1)}h"
            for c in cats
        ]
        total_time = sum(c.get("readingTime", 0) for c in (data.get("preferCategory") or []))
        practical_time = sum(
            c.get("readingTime", 0) for c in (data.get("preferCategory") or [])
            if c.get("categoryTitle") in PRACTICAL_CATEGORIES
        )
        pct_suffix = ""
        if total_time > 0:
            pct = round(practical_time / total_time * 100)
            if pct >= 80:
                pct_suffix = f"（实用书 ≈ {pct}%）"
        lines.append(f"> - **类别偏好**（按时长）：{' · '.join(parts)}{pct_suffix}")

    # 微信读书提炼一句话
    word_bits = [data.get("preferCategoryWord", ""), data.get("preferTimeWord", "")]
    word_bits = [w for w in word_bits if w]
    if word_bits:
        lines.append(f"> - **微信读书提炼**：{' · '.join(word_bits)}")

    # 作者 Top 5（按 readTime 字符串解析后的分钟数排序）
    authors = sorted(
        data.get("preferAuthor") or [],
        key=lambda a: _parse_chinese_duration(a.get("readTime", "")),
        reverse=True,
    )[:5]
    if authors:
        parts = [f"[[{a['name']}]] {a['readTime']}" for a in authors if a.get("name")]
        author_count = data.get("authorCount", 0)
        lines.append(
            f"> - **最爱作者**（按时长 Top 5）：{' · '.join(parts)}"
            f"（共读过 **{author_count} 位作者**）"
        )

    # 24h 时段分布（紧凑 4 列 × 6 行）
    pt = data.get("preferTime") or []
    if len(pt) == 24 and max(pt) > 0:
        maxv = max(pt)
        peak_hour = pt.index(maxv)
        lines.append("> - **阅读时段**（24h 分布）：")
        lines.append("> ```")
        for row in range(6):
            row_cells = []
            for col in range(4):
                h = row + col * 6
                if h >= 24:
                    continue
                bar = ascii_bar(pt[h], maxv, width=15)
                row_cells.append(f"{h:02d} {bar:<15}")
            lines.append("> " + "    ".join(row_cells))
        lines.append("> ```")
        lines.append(f">   峰值时段：**{peak_hour:02d} 点**")

        # 白天读书人洞察
        night = sum(pt[18:24])
        total = sum(pt)
        if total > 0 and night / total < 0.10:
            lines.append(">   **白天读书人**：04-17 为主，18 后几乎不读")

    return "\n".join(lines)


def build_profile_markdown(data):
    """组装数量 + 品味两个 callout 为完整 markdown 段。"""
    return "\n\n".join([
        build_quantity_callout(data),
        build_taste_callout(data),
    ])


